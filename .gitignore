# Ignore everything by default
*

# Force include .gitignore, picom.conf, and directories with contents
!.gitignore
!picom.conf
!nvim/
!wezterm/
!waybar/
!kitty/
!hypr/
!fuzzel/
!waypaper/


# Ensure contents within these directories are included
!nvim/**
nvim/*.json
!wezterm/**
!waybar/**
!kitty/**
!hypr/**
!fuzzel/**
!waypaper/**

